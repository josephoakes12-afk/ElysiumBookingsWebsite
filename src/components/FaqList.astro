---
interface Item {
  question: string;
  answer: string;
}

interface Props {
  items: readonly Item[];
}

const { items } = Astro.props;
---

<div class="faq-list">
  {
    items.map((item) => (
      <details class="faq-item">
        <summary>{item.question}</summary>
        <p>{item.answer}</p>
      </details>
    ))
  }
</div>
