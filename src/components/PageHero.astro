---
interface Props {
  eyebrow?: string;
  title: string;
  summary: string;
}

const { eyebrow, title, summary } = Astro.props;
---

<section class="container pt-10 sm:pt-14">
  <div class="page-hero">
    {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
    <h1 class="page-title">{title}</h1>
    <p class="page-summary">{summary}</p>
  </div>
</section>

