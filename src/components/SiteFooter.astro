---
import { siteConfig } from "../config/site";
---

<footer class="site-footer">
  <div class="container space-y-8 py-12">
    <div class="grid gap-8 lg:grid-cols-[1.3fr_repeat(3,minmax(0,1fr))]">
      <div class="space-y-3">
        <p class="eyebrow">Elysium Bookings</p>
        <h2 class="font-serif text-2xl text-white">{siteConfig.tagline}</h2>
        <p class="max-w-md text-sm text-white/70">{siteConfig.description}</p>
      </div>

      <div>
        <h3 class="footer-heading">Product</h3>
        <ul class="footer-links">
          {siteConfig.footerNavigation.product.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
        </ul>
      </div>

      <div>
        <h3 class="footer-heading">Company</h3>
        <ul class="footer-links">
          {siteConfig.footerNavigation.company.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
        </ul>
      </div>

      <div>
        <h3 class="footer-heading">Legal</h3>
        <ul class="footer-links">
          {siteConfig.footerNavigation.legal.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
          <li><a href={`mailto:${siteConfig.contact.supportEmail}`}>{siteConfig.contact.supportEmail}</a></li>
        </ul>
      </div>
    </div>

    <div class="flex flex-col gap-3 border-t border-white/10 pt-6 text-sm text-white/60 md:flex-row md:items-center md:justify-between">
      <p>&copy; 2026 {siteConfig.name}. All rights reserved.</p>
      <p>Booking, admin, and clearer business visibility for UK beauty professionals.</p>
    </div>
  </div>
</footer>
