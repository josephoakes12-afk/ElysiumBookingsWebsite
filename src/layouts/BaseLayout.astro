---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { absoluteUrl, pageTitle, siteConfig } from "../config/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
}

const {
  title,
  description = siteConfig.description,
  pathname = "/"
} = Astro.props;

const canonical = absoluteUrl(pathname);
const metadataTitle = pageTitle(title);
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: siteConfig.name,
  url: siteConfig.url,
  email: siteConfig.contact.supportEmail
};
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metadataTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#223A58" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:title" content={metadataTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteUrl("/og-card.svg")} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metadataTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteUrl("/og-card.svg")} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </head>
  <body>
    <div class="page-shell">
      <SiteHeader currentPath={pathname} />
      <main class="site-main">
        <slot />
      </main>
      <SiteFooter />
      <div class="cookie-banner" data-cookie-banner hidden>
        <p class="cookie-banner__text">
          This site uses essential cookies to keep the website working smoothly. Read the
          <a class="link-inline" href="/privacy">Privacy Policy</a>.
        </p>
        <button class="button button--secondary cookie-banner__button" type="button" data-cookie-dismiss>
          Dismiss
        </button>
      </div>
    </div>
    <script is:inline>
      const cookieBannerKey = "elysium-cookie-banner-dismissed";
      const cookieBanner = document.querySelector("[data-cookie-banner]");
      const cookieDismiss = document.querySelector("[data-cookie-dismiss]");

      if (cookieBanner instanceof HTMLElement) {
        let dismissed = false;

        try {
          dismissed = localStorage.getItem(cookieBannerKey) === "true";
        } catch {
          dismissed = false;
        }

        cookieBanner.hidden = dismissed;

        if (cookieDismiss instanceof HTMLButtonElement) {
          cookieDismiss.addEventListener("click", () => {
            cookieBanner.hidden = true;

            try {
              localStorage.setItem(cookieBannerKey, "true");
            } catch {
              // Ignore storage failures and just hide the banner for this visit.
            }
          });
        }
      }
    </script>
  </body>
</html>
