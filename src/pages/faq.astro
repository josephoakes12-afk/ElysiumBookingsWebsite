---
import FaqList from "../components/FaqList.astro";
import PageHero from "../components/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
---

<BaseLayout
  pathname="/faq"
  title="FAQ"
  description="Find answers about Elysium Bookings, including business fit, pre-launch plans, the current feature set, and the features coming soon."
>
  <PageHero
    eyebrow="FAQ"
    title="Answers for beauty businesses exploring Elysium."
    summary="Common questions about fit, workflow, launch plans, and what is available today versus what is still coming soon."
  />

  <section class="container mt-12">
    <FaqList items={siteConfig.faqs} />
  </section>
</BaseLayout>
