---
import FaqList from "../components/FaqList.astro";
import PageHero from "../components/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
---

<BaseLayout
  pathname="/faq"
  title="FAQ"
  description="Find answers about Elysium Bookings, including business fit, live features, client import, no-show protection, and what is coming next."
>
  <PageHero
    eyebrow="FAQ"
    title="Answers for beauty businesses exploring Elysium."
    summary="Common questions about fit, workflow, integrations, and what is available today."
  />

  <section class="container mt-12">
    <FaqList items={siteConfig.faqs} />
  </section>
</BaseLayout>
