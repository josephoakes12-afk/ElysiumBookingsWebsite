---
import PageHero from "../components/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
---

<BaseLayout pathname="/contact" title="Contact" description="Contact Elysium Bookings.">
  <PageHero
    eyebrow="Contact"
    title="Need help, verification details, or a product conversation?"
    summary="Email is the clearest route for support, verification checks, and product conversations."
  />

  <section class="container mt-12 grid gap-6 lg:grid-cols-2">
    <article class="content-panel">
      <p class="eyebrow">Support</p>
      <h2 class="mt-3 text-2xl font-semibold text-brand-navy">Email support</h2>
      <p class="mt-4 text-base leading-8 text-slate-600">
        For support, verification checks, or general enquiries, email <a class="link-inline" href={`mailto:${siteConfig.contact.supportEmail}`}>{siteConfig.contact.supportEmail}</a>.
      </p>
      <a class="button button--primary mt-6" href={`mailto:${siteConfig.contact.supportEmail}`}>Email support</a>
    </article>

    <article class="content-panel">
      <p class="eyebrow">Legal and privacy</p>
      <h2 class="mt-3 text-2xl font-semibold text-brand-navy">Privacy contact</h2>
      <p class="mt-4 text-base leading-8 text-slate-600">
        Privacy-related requests can be sent to <a class="link-inline" href={`mailto:${siteConfig.contact.privacyEmail}`}>{siteConfig.contact.privacyEmail}</a>.
      </p>
      <div class="mt-6 rounded-[1.5rem] bg-slate-50 p-5 text-sm leading-7 text-slate-600">
        Registered details placeholder: {siteConfig.legal.businessLegalName}, {siteConfig.legal.registeredAddress}
      </div>
    </article>
  </section>
</BaseLayout>
