---
import FaqList from "../components/FaqList.astro";
import FeatureCard from "../components/FeatureCard.astro";
import PricingCard from "../components/PricingCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";

const homeHighlightTitles = [
  "Client booking flow",
  "Aftercare per service",
  "Financial summary dashboard",
  "Google Sheets export"
];

const homeHighlights = siteConfig.featureTruth.liveNow.filter((item) => homeHighlightTitles.includes(item.title));
---

<BaseLayout
  pathname="/"
  title="Booking Software for UK Beauty and Wellness Businesses"
  description="Elysium Bookings is a pre-launch mobile-first booking platform for UK beauty and wellness businesses, with practical admin tools, aftercare support, clearer sole-trader reporting, and an active waitlist."
>
  <section class="container pt-10 sm:pt-14">
    <div class="hero-panel grid gap-10 lg:grid-cols-[1.25fr_0.75fr] lg:items-end">
      <div>
        <p class="eyebrow">Pre-launch beauty booking software</p>
        <h1 class="page-title">{siteConfig.homepage.heroTitle}</h1>
        <p class="page-summary">{siteConfig.homepage.heroSummary}</p>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600">
          Built for beauty and wellness businesses across the UK, with a particularly strong fit for solo and micro operators joining ahead of launch.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="button button--primary" href={siteConfig.ctas.primary.href}>{siteConfig.ctas.primary.label}</a>
          <a class="button button--secondary" href={siteConfig.ctas.secondary.href}>{siteConfig.ctas.secondary.label}</a>
        </div>
      </div>

      <div class="content-panel">
        <p class="eyebrow">Why join early</p>
        <ul class="mt-4 space-y-4 text-sm leading-7 text-slate-600">
          <li>Mobile-first booking and admin designed around the day-to-day reality of UK solo and micro beauty businesses.</li>
          <li>Join the waitlist to hear when client import tools and no-show protection become available.</li>
          <li>See the product direction early, with aftercare, reporting, and practical admin at the heart of the platform.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="container mt-16">
    <p class="eyebrow">Who it is for</p>
    <h2 class="section-title mt-3">{siteConfig.homepage.audienceTitle}</h2>
    <div class="chip-row mt-8">
      {siteConfig.focusSegments.map((item) => <span class="chip">{item}</span>)}
    </div>
  </section>

  <section class="container mt-16 grid gap-6 md:grid-cols-3">
    {siteConfig.homepage.differentiators.map((item) => <FeatureCard title={item.title} description={item.description} />)}
  </section>

  <section class="container mt-16">
    <p class="eyebrow">Feature highlights</p>
    <div class="mt-6 grid gap-6 lg:grid-cols-2">
      {homeHighlights.map((item) => <FeatureCard title={item.title} description={item.description} />)}
    </div>
  </section>

  <section class="container mt-16">
    <div class="content-panel">
      <p class="eyebrow">Tax and admin value</p>
      <h2 class="section-title mt-3">Built to make sole-trader admin less messy.</h2>
      <div class="mt-6 grid gap-5 md:grid-cols-3">
        {siteConfig.homepage.soleTraderPoints.map((item) => <div class="value-card"><p>{item}</p></div>)}
      </div>
    </div>
  </section>

  <section class="container mt-16">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow">Pricing</p>
        <h2 class="section-title mt-3">Simple monthly plans, ready for when Elysium launches publicly.</h2>
        <p class="section-summary mt-3">Free, Starter, and Pro are the planned monthly tiers after launch. Join the waitlist to hear when access opens.</p>
      </div>
      <a class="button button--ghost" href="/pricing#waitlist">Join the waitlist</a>
    </div>
    <div class="mt-8 grid gap-6 lg:grid-cols-3">
      {siteConfig.pricing.map((tier) => <PricingCard {...tier} />)}
    </div>
  </section>

  <section class="container mt-16">
    <div class="content-panel">
      <p class="eyebrow">FAQ</p>
      <h2 class="section-title mt-3">Straight answers for businesses checking fit.</h2>
      <div class="mt-8">
        <FaqList items={siteConfig.homepage.faqs} />
      </div>
    </div>
  </section>

  <section class="container mt-16">
    <div class="content-panel">
      <p class="eyebrow">Trust</p>
      <h2 class="section-title mt-3">Transparent from the start.</h2>
      <p class="section-summary">We keep the essentials easy to find, including our privacy policy, terms, address, and direct contact details, so you can check who is behind Elysium before launch and beyond.</p>
    </div>
  </section>
</BaseLayout>
